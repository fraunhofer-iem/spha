{
  "name": "metric-catalogue",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "metrics:build": "node --import tsx scripts/build-metrics-index.ts",
    "build": "npm run metrics:build && vue-tsc -p tsconfig.app.json && vite build",
    "test:node": "NODE_OPTIONS=--import=tsx node --test scripts/__tests__/*.ts",
    "test:ui": "vitest run",
    "test": "npm run test:node && npm run test:ui",
    "preview": "vite preview",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "dependencies": {
    "d3": "7.9.0",
    "dompurify": "3.4.11",
    "gray-matter": "4.0.3",
    "lucide-vue-next": "1.0.0",
    "marked": "18.0.5",
    "vue": "3.5.38",
    "vue-router": "5.1.0",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@testing-library/vue": "8.1.0",
    "@types/d3": "7.4.3",
    "@types/node": "25.6.0",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/tsconfig": "0.9.1",
    "happy-dom": "20.10.6",
    "jsdom": "29.1.1",
    "prettier": "3.8.4",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vitest": "4.1.9",
    "vue-tsc": "3.3.5"
  },
  "overrides": {
    "vite": "8.1.0"
  }
}
